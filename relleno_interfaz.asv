Z=handles.vertices(cell2mat(handles.h_modify),3);

longitudes=cellfun('prodofsize',handles.h_modify);

separacion_huecos=[];
for indal=1:length(longitudes)
    separacion_huecos=[separacion_huecos indal*ones(1,longitudes(1,indal))];
end


%     handles.dibu=plot3(handles.vertices(handles.h_modify{k},1),handles.vertices(handles.h_modify{k},2),handles.vertices(handles.h_modify{k},3),'b','LineWidth',2);
