% --- Executes on button press in pushbutton4.
function pushbutton4_Callback(hObject, eventdata, handles)
% hObject    handle to pushbutton4 (see GCBO)
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)
gruposcaras=finddisconnsurf(handles.caras);
if (size(gruposcaras,2)>1)
    islotes=cellfun('length',gruposcaras);
    [islamax,indisla]=max(islotes);
    [filmax,colmax]=find(islotes<islamax*0.10);
    islasvalidas=setdiff(1:length(islotes),colmax);
    handles.caras=[];
    for indimax=1:(length(islasvalidas))
        handles.caras=[handles.caras;gruposcaras{1,islasvalidas(indimax)}];
    end
    
    disp(['Se han eliminado ' num2str((size(gruposcaras,2)-1)) ' grupos']);
end


delete(handles.ppp);
if(~isempty(handles.h_modify))
    delete(handles.agujeros);
end
handles.h_modify=EncuentraHuecos(handles.caras,handles.vertices,0,0);
if(length(handles.normales)~=length(handles.vertices))
    [handles.normales,normalesf] = compute_normal(handles.vertices,handles.caras);
    handles.normales=handles.normales';
end


handles.camara.posicion = get(gca,'CameraPosition');
handles.camara.angulo = get(gca,'CameraViewAngle');
handles.camara.objetivo = get(gca,'CameraTarget');
handles=representacion(hObject, handles);
handles.agujeros=[];
for k=1:length(handles.h_modify)
    handles.dibu=plot3(handles.vertices(handles.h_modify{k},1),handles.vertices(handles.h_modify{k},2),handles.vertices(handles.h_modify{k},3),'b','LineWidth',2);
    handles.agujeros=[handles.agujeros;handles.dibu];
end
handles.filu_anterior=0;


handles.ptos2=[];
handles.puntos_bordes=cell2mat(handles.h_modify);
guidata(hObject, handles);



function handles=representacion(hObject, handles)

opengl hardware;
set(handles.figure1,'Renderer','OpenGL');
hold on;
% cla;
if(isfield(handles,'luz1'))
    delete(handles.luz1);
    delete(handles.luz2);
    delete(handles.luz3);
    %      handles=rmfield(handles, 'luz1');
    %       handles=rmfield(handles, 'luz2');
    %                     handles=rmfield(handles, 'ultimo_punto');
end


% set(handles.axes1,'Color',[1 1 1]);%,'Position',[10 258   560   420]);
set(handles.axes1,'Visible','off');%,'CameraPosition',camara);
axes(handles.axes1);



handles.luz1=light('Position',[handles.maximov(1,1) 0 handles.maximov(1,3)/2],'Style','infinite');     % add a default light
handles.luz2=light('Position',[-handles.maximov(1,1) 0 handles.maximov(1,3)/2],'Style','infinite');
daspect([1 1 1]);                                                        % Setting the aspect ratio



handles.ppp = patch('faces', handles.caras, 'vertices' ,handles.vertices, 'FaceAlpha', 1, 'VertexNormals', handles.normales);
% set(handles.ppp, 'facec', 'interp');                                                % Set the face color interp
set(handles.ppp, 'FaceVertexCData', 0.5*ones(length(handles.vertices),1));                                           % Set the color (from file)



% handles.c2 = datacursormode(handles.figure1);
% set(handles.c2,'DisplayStyle','window','SnapToDataVertex','on');
%
% datacursormode on;
% rotate3d on;
cameratoolbar('SetMode','orbit');
handles.luz3=camlight;
lighting(handles.axes1,handles.modo_li);
shading(handles.axes1,handles.modo_sh);
if(handles.visualizacion.aristas)
    set(handles.ppp, 'EdgeColor','k');
else
    set(handles.ppp, 'EdgeColor','none');
end

if(handles.camara.objetivo==0)
    set(handles.axes1,'CameraTargetMode','auto');
    set(handles.axes1,'CameraPositionMode','auto');
    set(handles.axes1,'CameraViewAngleMode','auto');
else
    
    set(handles.axes1,'CameraTarget',handles.camara.objetivo);
    set(handles.axes1,'CameraPosition',handles.camara.posicion);
    set(handles.axes1,'CameraViewAngle',handles.camara.angulo);
end



drawnow;
guidata(hObject, handles);


