guidata(hObject, handles);


% --- Executes on button press in pushbutton11.
function pushbutton11_Callback(hObject, eventdata, handles)
% hObject    handle to pushbutton11 (see GCBO)
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)
axes(handles.axes1);
% k=[1,1:3);

% for k=1:length(handles.h_modify)
X=handles.vertices(cell2mat(handles.h_modify(setdiff(1:length(handles.h_modify),handles.huecos_selec))),1);
Y=handles.vertices(cell2mat(handles.h_modify(setdiff(1:length(handles.h_modify),handles.huecos_selec))),2);
Z=handles.vertices(cell2mat(handles.h_modify(setdiff(1:length(handles.h_modify),handles.huecos_selec))),3);

longitudes=cellfun('prodofsize',handles.h_modify);
lista_huecos=1:length(handles.h_modify);

longitudes(handles.huecos_selec)=[];
lista_huecos(handles.huecos_selec)=[];
separacion_huecos=[];

for indal=1:length(longitudes)
    separacion_huecos=[separacion_huecos lista_huecos(indal)*ones(1,longitudes(1,indal))];
end


puntos_scater=scatter3(X(:),Y(:),Z(:),'filled');

% Draw red circles around selected points
SS=rbb3select(X,Y,Z);



% hold on
% scatter3(X(find(SS)),Y(find(SS)),Z(find(SS)),'o','r');
handles.huecos_selec=sort(unique([handles.huecos_selec;  setdiff(SS.*separacion_huecos',0)]));
delete(handles.agujeros(handles.huecos_selec));
delete(puntos_scater);

for indul=1:length(handles.huecos_selec)
    handles.agujeros(handles.huecos_selec(indul))=plot3(handles.vertices(handles.h_modify{handles.huecos_selec(indul)},1),handles.vertices(handles.h_modify{handles.huecos_selec(indul)},2),handles.vertices(handles.h_modify{handles.huecos_selec(indul)},3),'r','LineWidth',5);
    
end

guidata(hObject, handles);

% --- Executes on button press in pushbutton12.
function pushbutton12_Callback(hObject, eventdata, handles)
% hObject    handle to pushbutton12 (see GCBO)
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)
axes(handles.axes1);
% k=[1,1:3);

% for k=1:length(handles.h_modify)
X=handles.vertices(cell2mat(handles.h_modify(handles.huecos_selec)),1);
Y=handles.vertices(cell2mat(handles.h_modify(handles.huecos_selec)),2);
Z=handles.vertices(cell2mat(handles.h_modify(handles.huecos_selec)),3);

longitudes=cellfun('prodofsize',handles.h_modify);
lista_huecos=1:length(handles.h_modify);

longitudes(setdiff(1:length(handles.h_modify),handles.huecos_selec))=[];
lista_huecos(setdiff(1:length(handles.h_modify),handles.huecos_selec))=[];
separacion_huecos=[];

for indal=1:length(longitudes)
    separacion_huecos=[separacion_huecos lista_huecos(indal)*ones(1,longitudes(1,indal))];
end


puntos_scater=scatter3(X(:),Y(:),Z(:),'filled','r');

% Draw red circles around selected points
SS=rbb3select(X,Y,Z);



% hold on
% scatter3(X(find(SS)),Y(find(SS)),Z(find(SS)),'o','r');
eliminados=setdiff(SS.*separacion_huecos',0);
handles.huecos_selec=setdiff(handles.huecos_selec,eliminados);
delete(handles.agujeros(handles.huecos_selec));
delete(handles.agujeros(eliminados));
delete(puntos_scater);

for indul=1:length(handles.huecos_selec)
    handles.agujeros(handles.huecos_selec(indul))=plot3(handles.vertices(handles.h_modify{handles.huecos_selec(indul)},1),handles.vertices(handles.h_modify{handles.huecos_selec(indul)},2),handles.vertices(handles.h_modify{handles.huecos_selec(indul)},3),'r','LineWidth',5);
    
end
for indul=1:length(eliminados)
    handles.agujeros(eliminados(indul))=plot3(handles.vertices(handles.h_modify{eliminados(indul)},1),handles.vertices(handles.h_modify{eliminados(indul)},2),handles.vertices(handles.h_modify{eliminados(indul)},3),'b','LineWidth',2);
    
end

guidata(hObject, handles);





function scroll_zoom(varargin)
MainFig=varargin{1};
% (varargin,handles)
        % double check if these axes are indeed the current axes
%         axs=handles.axes1;
%         if get(MainFig, 'currentaxes') ~= axs, return, end
axs=get(MainFig,'CurrentAxes');
        % get the amount of scolls
        scrolls = varargin{2}.VerticalScrollCount;
        % get the axes' x- and y-limits
        xlim = get(axs, 'xlim');  ylim = get(axs, 'ylim');
        % get the current camera position, and save the [z]-value
        cam_pos_Z = get(axs, 'cameraposition');  cam_pos_Z = cam_pos_Z(3);
        % get the current point
        old_position = get(axs, 'CurrentPoint'); old_position(1,3) = cam_pos_Z;
        % calculate zoom factor
        zoomfactor = 1 - scrolls/50;
        % adjust camera position
        set(axs, 'cameratarget', [old_position(1, 1:2), 0],...
            'cameraposition', old_position(1, 1:3));
        % adjust the camera view angle (equal to zooming in)
        camzoom(zoomfactor);
        % zooming with the camera has the side-effect of
        % NOT adjusting the axes limits. We have to correct for this:
        x_lim1 = (old_position(1,1) - min(xlim))/zoomfactor;
        x_lim2 = (max(xlim) - old_position(1,1))/zoomfactor;
        xlim   = [old_position(1,1) - x_lim1, old_position(1,1) + x_lim2];
        y_lim1 = (old_position(1,2) - min(ylim))/zoomfactor;
        y_lim2 = (max(ylim) - old_position(1,2))/zoomfactor;
        ylim   = [old_position(1,2) - y_lim1, old_position(1,2) + y_lim2];
        set(axs, 'xlim', xlim), set(axs, 'ylim', ylim)
        % set new camera position
        new_position = get(axs, 'CurrentPoint');
        old_camera_target =  get(axs, 'CameraTarget');
        old_camera_target(3) = cam_pos_Z;
        new_camera_position = old_camera_target - ...
            (new_position(1,1:3) - old_camera_target(1,1:3));
        % adjust camera target and position
        set(axs, 'cameraposition', new_camera_position(1, 1:3),...
            'cameratarget', [new_camera_position(1, 1:2), 0]);
        % we also have to re-set the axes to stretch-to-fill mode
        set(axs, 'cameraviewanglemode', 'auto',...
            'camerapositionmode', 'auto',...
            'cameratargetmode', 'auto');
        
        
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%% FUNCIONES PARA REALIZAR EL PAN
function pan_click(varargin)
    
    MainFig=varargin{1};
axs=get(MainFig,'CurrentAxes');
        % double check if these axes are indeed the current axes
        if get(MainFig, 'currentaxes') ~= axs, return, end
        % perform appropriate action
        switch lower(get(MainFig, 'selectiontype'))            
            % start panning on left click
            case 'extend' 
                status = 'down';
                previous_point = get(axs, 'CurrentPoint');              
            % reset view on double click
            case 'open' % double click (left or right)
                set(axs, 'Xlim', original_xlim,...
                         'Ylim', original_ylim);  
            % right click - set new reset state
%             case 'alt'
%                 original_xlim = get(axs, 'xlim');
%                 original_ylim = get(axs, 'ylim');
        end

    
    % release mouse button
    function pan_release(varargin)
            MainFig=varargin{1};
axs=get(MainFig,'CurrentAxes');
        % double check if these axes are indeed the current axes
        if get(MainFig, 'currentaxes') ~= axs, return, end
        switch lower(get(MainFig, 'selectiontype')) 
        % just reset status
         case 'extend' 
        status = '';
        end
    
    
    % move the mouse (with button clicked)
    function pan_motion(varargin)
            MainFig=varargin{1};
axs=get(MainFig,'CurrentAxes');
        % double check if these axes are indeed the current axes
        if get(MainFig, 'currentaxes') ~= axs, return, end
         switch lower(get(MainFig, 'selectiontype')) 
              case 'extend' 
        % return if there isn't a previous point
        if isempty(previous_point), return, end  
        % return if mouse hasn't been clicked
        if isempty(status), return, end  
        % get current location (in pixels)
        current_point = get(axs, 'CurrentPoint');
        % get current XY-limits
        xlim = get(axs, 'xlim');  ylim = get(axs, 'ylim');     
        % find change in position
        delta_points = current_point - previous_point;  
        % adjust limits
        new_xlim = xlim - delta_points(1); 
        new_ylim = ylim - delta_points(3); 
        % set new limits
        set(axs, 'Xlim', new_xlim); set(axs, 'Ylim', new_ylim);           
        % save new position
        previous_point = get(axs, 'CurrentPoint');
         end
     
