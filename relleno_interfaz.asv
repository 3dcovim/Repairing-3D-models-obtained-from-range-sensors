function varargout = relleno_interfaz(varargin)
% RELLENO_INTERFAZ M-file for relleno_interfaz.fig
%      RELLENO_INTERFAZ, by itself, creates a new RELLENO_INTERFAZ or raises the existing
%      singleton*.
%
%      H = RELLENO_INTERFAZ returns the handle to a new RELLENO_INTERFAZ or the handle to
%      the existing singleton*.
%
%      RELLENO_INTERFAZ('CALLBACK',hObject,eventData,handles,...) calls the local
%      function named CALLBACK in RELLENO_INTERFAZ.M with the given input arguments.
%
%      RELLENO_INTERFAZ('Property','Value',...) creates a new RELLENO_INTERFAZ or raises the
%      existing singleton*.  Starting from the left, property value pairs are
%      applied to the GUI before relleno_interfaz_OpeningFcn gets called.  An
%      unrecognized property name or invalid value makes property application
%      stop.  All inputs are passed to relleno_interfaz_OpeningFcn via varargin.
%
%      *See GUI Options on GUIDE's Tools menu.  Choose "GUI allows only one
%      instance to run (singleton)".
%
% See also: GUIDE, GUIDATA, GUIHANDLES

% Edit the above text to modify the response to help relleno_interfaz

% Last Modified by GUIDE v2.5 21-Nov-2010 18:04:27

% Begin initialization code - DO NOT EDIT
gui_Singleton = 1;
gui_State = struct('gui_Name',       mfilename, ...
    'gui_Singleton',  gui_Singleton, ...
    'gui_OpeningFcn', @relleno_interfaz_OpeningFcn, ...
    'gui_OutputFcn',  @relleno_interfaz_OutputFcn, ...
    'gui_LayoutFcn',  [] , ...
    'gui_Callback',   []);
if nargin && ischar(varargin{1})
    gui_State.gui_Callback = str2func(varargin{1});
end

if nargout
    [varargout{1:nargout}] = gui_mainfcn(gui_State, varargin{:});
else
    gui_mainfcn(gui_State, varargin{:});
end
% End initialization code - DO NOT EDIT


% --- Executes just before relleno_interfaz is made visible.
function relleno_interfaz_OpeningFcn(hObject, eventdata, handles, varargin)
% This function has no output args, see OutputFcn.
% hObject    handle to figure
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)
% varargin   command line arguments to relleno_interfaz (see VARARGIN)

% Choose default command line output for relleno_interfaz
handles.output = hObject;
handles.caras= varargin{1};
handles.vertices= varargin{2};
handles.normales= varargin{3};
handles.h_modify= varargin{4};
handles.camara= varargin{5};
handles.visualizacion= varargin{6};
handles.selec_automatic_parche= varargin{7};
handles.extension_parche= varargin{8};

handles.huecos_selec=[];


handles.terminar2=0;
handles.output=0;
handles.maximov=max(handles.vertices);

set(handles.checkbox1,'Value',handles.visualizacion.aristas);
set(handles.edit1,'String',num2str(handles.extension_parche));
set(handles.edit1,'Enable','off');
set(handles.checkbox3,'Value',~handles.selec_automatic_parche);
set(handles.pushbutton5,'Enable','off');

% scrsz = get(0,'ScreenSize'); %Vemos cuál es el tamańo de la pantalla

set(handles.figure1,'Position',[25 25 205 46]);
cameratoolbar('Show');
handles.modo_sh='Flat';
handles.modo_li='None';

set(handles.figure1,'WindowScrollWheelFcn' , @scroll_zoom);
set(handles.figure1,'WindowButtonDownFcn'  , @pan_click);
set(handles.figure1, 'WindowButtonUpFcn'  ,@pan_release);
set(handles.figure1, 'WindowButtonMotionFcn' , @pan_motion);

 

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%% PRIMERA REPRESENTACION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

handles=representacion(hObject,handles);
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%% FIN PRIMERA REPRESENTACION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
handles.agujeros=[];
hold on;
% figure(f2),hold on
for k=1:length(handles.h_modify)
    handles.dibu=plot3(handles.vertices(handles.h_modify{k},1),handles.vertices(handles.h_modify{k},2),handles.vertices(handles.h_modify{k},3),'b','LineWidth',2);
    handles.agujeros=[handles.agujeros;handles.dibu];
end

handles.filu_anterior=0;

handles.ptos2=[];
handles.puntos_bordes=cell2mat(handles.h_modify);

% set(handles.figure1,'KeyPressFcn',@printfig);


% Update handles structure
guidata(hObject, handles);

% UIWAIT makes relleno_interfaz wait for user response (see UIRESUME)
% uiwait(handles.figure1);


% --- Outputs from this function are returned to the command line.
function varargout = relleno_interfaz_OutputFcn(hObject, eventdata, handles)
% varargout  cell array for returning output args (see VARARGOUT);
% hObject    handle to figure
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)

% Get default command line output from handles structure
varargout{1} = handles.output;


% --- Executes on button press in pushbutton5.
function pushbutton5_Callback(hObject, eventdata, handles)
% hObject    handle to pushbutton5 (see GCBO)
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)
info2=getCursorInfo(handles.c2);
if  ~isempty(info2)
    
    %             ptos2=[ptos2;info2.Position];
    %             color_pto=rand(1,3);
    
    %             figure(f2),hold on
    %             plot3(ptos2(end,1),ptos2(end,2),ptos2(end,3),'o','MarkerEdgeColor','k',...
    %                 'MarkerFaceColor',color_pto,...
    %                 'MarkerSize',10)
    
    punto_select=info2.Position;
    
    distancias_bor=sqrt(sum((handles.vertices(handles.puntos_bordes',:)-punto_select(ones(length(handles.puntos_bordes),1),:)).^2,2));
    [filob,colob]=min(distancias_bor);
    [filw,colw]=find(colob-cumsum(cellfun('length',handles.h_modify))>0);
    
    if(~isempty(colw))
        [filu,colu]=max(colw);
        filu=filu+1;
    else
        filu=1;
    end
    if(distancias_bor(colob)<20)
        %                 set(agujeros(filu),'Visible','off');
        
        if(filu~=handles.filu_anterior)
            delete(handles.agujeros(filu));
            
            if(isfield(handles,'ultimo_punto'))
                delete(handles.ultimo_punto);
                handles=rmfield(handles, 'ultimo_punto');
            end
            if(isfield(handles,'ultimo_borde'))
                delete(handles.ultimo_borde);
                handles=rmfield(handles, 'ultimo_borde');
            end
            if(handles.filu_anterior~=0)
                handles.agujeros(handles.filu_anterior)=plot3(handles.vertices(handles.h_modify{handles.filu_anterior},1),handles.vertices(handles.h_modify{handles.filu_anterior},2),handles.vertices(handles.h_modify{handles.filu_anterior},3),'b','LineWidth',2);
            end
            
            handles.ultimo_borde=plot3(handles.vertices(handles.h_modify{filu},1),handles.vertices(handles.h_modify{filu},2),handles.vertices(handles.h_modify{filu},3),'r','LineWidth',5);
        end
        handles.filu_anterior=filu;
        
        
        
    else
        handles.ptos2=[handles.ptos2;info2.Position];
        color_pto='y';
        if(isfield(handles,'ultimo_punto'))
            delete(handles.ultimo_punto);
            handles=rmfield(handles, 'ultimo_punto');
        end
        if(isfield(handles,'ultimo_borde'))
            delete(handles.ultimo_borde);
            handles=rmfield(handles, 'ultimo_borde');
        end
        %                 figure(f2),hold on
        handles.ultimo_punto=plot3(handles.ptos2(end,1),handles.ptos2(end,2),handles.ptos2(end,3),'o','MarkerEdgeColor','k',...
            'MarkerFaceColor',color_pto,...
            'MarkerSize',10);
        if(handles.filu_anterior~=0)
            handles.agujeros(handles.filu_anterior)=plot3(handles.vertices(handles.h_modify{handles.filu_anterior},1),handles.vertices(handles.h_modify{handles.filu_anterior},2),handles.vertices(handles.h_modify{handles.filu_anterior},3),'b','LineWidth',2);
        end
        
        
    end
end

guidata(hObject, handles);





% --- Executes on button press in pushbutton6.
function pushbutton6_Callback(hObject, eventdata, handles)
% hObject    handle to pushbutton6 (see GCBO)
% eventdata  reserved - to be defined in a future version of MATLAB
% handles    structure with handles and user data (see GUIDATA)
handles.aguje=handles.filu_anterior;
if(~(handles.aguje>0))
    disp('No se seleccionó ningún borde');
end
handles.output=1;
handles.camara.posicion = get(gca,'CameraPosition');
handles.camara.angulo = get(gca,'CameraViewAngle');
handles.camara.objetivo = get(gca,'CameraTarget');
handles.extension_parche= str2num(get(handles.edit1,'String'));
guidata(hObject, handles);


